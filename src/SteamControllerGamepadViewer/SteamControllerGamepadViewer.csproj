<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>SteamControllerGamepadViewer</AssemblyName>
    <RootNamespace>SteamControllerGamepadViewer</RootNamespace>
    <OutputType>WinExe</OutputType>
  </PropertyGroup>
  <ItemGroup>
    <EmbeddedResource Include="wwwroot\**\*">
      <LogicalName>wwwroot/%(RecursiveDir)%(Filename)%(Extension)</LogicalName>
    </EmbeddedResource>
    <None Include="..\..\LICENSE" Link="LICENSE" CopyToPublishDirectory="Always" />
    <None Include="..\..\README.md" Link="README.md" CopyToPublishDirectory="Always" />
    <None Include="..\..\THIRD_PARTY_NOTICES.md" Link="THIRD_PARTY_NOTICES.md" CopyToPublishDirectory="Always" />
  </ItemGroup>
</Project>
